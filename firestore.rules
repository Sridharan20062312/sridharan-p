rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // User Profile Validation
    function isValidUser(data) {
      return data.uid is string && data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             (!('phoneNumber' in data) || (data.phoneNumber is string && data.phoneNumber.size() <= 20)) &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
             (!('bio' in data) || (data.bio is string && data.bio.size() <= 300)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 200000)) &&
             (!('isSafetyOn' in data) || data.isSafetyOn is bool) &&
             (!('isLiveSharing' in data) || data.isLiveSharing is bool) &&
             (!('alertSound' in data) || (data.alertSound is string && data.alertSound.size() <= 500)) &&
             (!('geofenceSound' in data) || (data.geofenceSound is string && data.geofenceSound.size() <= 500));
    }

    function isValidSafeZone(data) {
      return data.name is string && data.name.size() <= 100 &&
             data.center is map &&
             data.center.latitude is number &&
             data.center.longitude is number &&
             data.radius is number && data.radius > 0 &&
             (!('notifyMe' in data) || data.notifyMe is bool) &&
             (!('notifyContacts' in data) || data.notifyContacts is bool);
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || resource.data.isLiveSharing == true);
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly([
                      'displayName', 'phoneNumber', 'lastKnownLocation', 'isSafetyOn', 
                      'isLiveSharing', 'alertSound', 'geofenceSound', 'emergencyContacts', 'updatedAt',
                      'photoURL', 'bio'
                    ]);

      match /safeZones/{zoneId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSafeZone(incoming());
        allow update: if isOwner(userId) && isValidSafeZone(incoming());
        allow delete: if isOwner(userId);
      }
    }

    // SOS Alert Validation
    function isValidSOS(data) {
      return data.userId is string && data.userId == request.auth.uid &&
             data.status in ['active', 'resolved'] &&
             data.timestamp == request.time &&
             data.location is map &&
             data.location.latitude is number &&
             data.location.longitude is number &&
             (!('targetGroup' in data) || data.targetGroup in ['all', 'Family', 'Friends', 'Other']);
    }

    match /alerts/{alertId} {
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.status == 'active'); 
      // Active alerts are public for this demo/safety purpose
      allow get: if isSignedIn();
      allow create: if isSignedIn() && isValidSOS(incoming());
      allow update: if isSignedIn() && (
        // Owner can resolve
        (isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
        // Admin or system could update other things
        false
      );
    }
  }
}
